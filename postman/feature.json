          "item": [
            {
              "name": "Добавление нового Place",
              "event": [
                {
                  "listen": "prerequest",
                  "script": {
                    "exec": [
                      "const main = async () => {\r",
                      "const place = {\r",
                      "    name: `Test_${Date.now()}`,\r",
                      "    lat: (Math.random() * 180 - 90).toFixed(6),     \r",
                      "    lon: (Math.random() * 360 - 180).toFixed(6),  \r",
                      "    radius: Math.floor(Math.random() * 1000) + 10\r",
                      "};\r",
                      " \r",
                      " \r",
                      "\r",
                      "    pm.request.body.update({\r",
                      "        mode: 'raw',\r",
                      "        raw: JSON.stringify(place),\r",
                      "        options: { raw: { language: 'json' } }\r",
                      "    });\r",
                      "};\r",
                      "\r",
                      "const interval = setInterval(() => {}, 1000);\r",
                      "\r",
                      "setTimeout(async () => \r",
                      "    {\r",
                      "        try {\r",
                      "            await main();\r",
                      "        } catch (e) {\r",
                      "            console.error(e);\r",
                      "        } finally {\r",
                      "            clearInterval(interval);\r",
                      "        }\r",
                      "    },  \r",
                      "    100 \r",
                      ");"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                },
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Ответ должен содержать код статуса 201 и данные в формате json\", function () {\r",
                      "    pm.response.to.have.status(201);\r",
                      "    pm.response.to.be.withBody;\r",
                      "    pm.response.to.be.json;\r",
                      "});\r",
                      "\r",
                      "const source = JSON.parse(pm.request.body.raw);\r",
                      "const target = pm.response.json();\r",
                      "\r",
                      "pm.test(\"Локация должна содержать id,lat,lon,radius\", function () {\r",
                      "    pm.expect(target).to.have.property('id');\r",
                      "    pm.expect(target).to.have.property('lat');\r",
                      "    pm.expect(target).to.have.property('lon');\r",
                      "    pm.expect(target).to.have.property('radius');\r",
                      "});\r",
                      "\r",
                      "pm.test(\"Данные в ответе должны соответствовать данным в запросе\", function () {\r",
                      "    pm.expect(target.id).to.not.be.null;\r",
                      "pm.expect(parseFloat(source.lat)).to.be.closeTo(parseFloat(target.lat), 6, \r",
                      "    'Lat должна соответствовать оригиналу с точностью до 6 знаков');\r",
                      "pm.expect(parseFloat(source.lon)).to.be.closeTo(parseFloat(target.lon), 6,\r",
                      "    'Lon должна соответствовать оригиналу с точностью до 6 знаков');\r",
                      "    pm.expect(source.radius).equal(target.radius, 'Radius должен соответствовать оригиналу');\r",
                      "});"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "Accept",
                    "value": "application/json"
                  }
